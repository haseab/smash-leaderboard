// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model players {
  id                    BigInt   @id @default(autoincrement())
  created_at            DateTime @default(now())
  name                  String?
  display_name          String  @unique
  elo                   BigInt   @default(1200)
  country               String?
  picture               String?
  banned                Boolean  @default(false)
  inactive              Boolean  @default(false)
  solo_team             Boolean  @default(false)
  top_ten_played        Int      @default(0)
  
  // Relations
  match_participants  match_participants[]
  character_rankings character_rankings[]
  team_rankings_player_one team_rankings[] @relation("team_rankings_player_one")
  team_rankings_player_two team_rankings[] @relation("team_rankings_player_two")
  
  @@index([elo(sort: Desc)], name: "idx_players_elo")
  @@map("players")
}

model matches {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now())
  archived   Boolean  @default(false)
  
  // Relations
  match_participants match_participants[]
  
  @@map("matches")
}

model match_participants {
  id              BigInt   @id @default(autoincrement())
  created_at      DateTime @default(now())
  match_id        BigInt
  player          BigInt
  smash_character String
  elo_diff        Int?
  is_cpu          Boolean  @default(false)
  total_kos       Int      @default(0)
  total_falls     Int      @default(0)
  total_sds       Int      @default(0)
  has_won         Boolean  @default(false)
  
  // Relations
  match   matches @relation(fields: [match_id], references: [id], onDelete: Cascade)
  players players @relation(fields: [player], references: [id], onDelete: Cascade)
  
  @@index([is_cpu, match_id])
  @@index([player, match_id(sort: Desc), has_won, is_cpu])
  @@index([player, smash_character])
  @@index([match_id, player, is_cpu])
  @@map("match_participants")
}

model character_rankings {
  id                 BigInt    @id @default(autoincrement())
  created_at         DateTime  @default(now())
  player             BigInt
  smash_character    String
  elo                BigInt    @default(1200)
  total_wins         Int       @default(0)
  total_losses       Int       @default(0)
  total_kos          Int       @default(0)
  total_falls        Int       @default(0)
  total_sds          Int       @default(0)
  current_win_streak Int       @default(0)
  last_match_date    DateTime?

  // Relations
  players players @relation(fields: [player], references: [id], onDelete: Cascade)

  @@unique([player, smash_character])
  @@index([elo(sort: Desc)], name: "idx_character_rankings_elo")
  @@index([player, last_match_date(sort: Desc)], name: "idx_character_rankings_player_last_match")
  @@map("character_rankings")
}

model team_rankings {
  id                 BigInt    @id @default(autoincrement())
  created_at         DateTime  @default(now())
  player_one         BigInt
  player_two         BigInt
  team_name          String?
  logo               String?
  elo                BigInt    @default(1200)
  total_wins         Int       @default(0)
  total_losses       Int       @default(0)
  total_kos          Int       @default(0)
  total_falls        Int       @default(0)
  total_sds          Int       @default(0)
  current_win_streak Int       @default(0)
  last_match_date    DateTime?

  // Relations
  player_one_player players @relation("team_rankings_player_one", fields: [player_one], references: [id], onDelete: Cascade)
  player_two_player players @relation("team_rankings_player_two", fields: [player_two], references: [id], onDelete: Cascade)

  @@unique([player_one, player_two])
  @@index([elo(sort: Desc)], name: "idx_team_rankings_elo")
  @@index([player_one, last_match_date(sort: Desc)], name: "idx_team_rankings_player_one_last_match")
  @@index([player_two, last_match_date(sort: Desc)], name: "idx_team_rankings_player_two_last_match")
  @@map("team_rankings")
}
